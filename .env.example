# Copier ce fichier en .env et remplir les valeurs

# Clé API Anthropic (Claude)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Clé API Firecrawl (enrichissement entreprises — optionnel)
# https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-...

# Clé RapidAPI pour récupérer les descriptions LinkedIn
# S'inscrire sur rapidapi.com → chercher "linkedin-job-search-api" → Subscribe (plan gratuit : 200 req/mois)
# https://rapidapi.com/fantastic-bit/api/linkedin-jobs-search ou équivalent
RAPIDAPI_KEY=

# ID du Google Sheets où écrire les résultats
# Laisser vide pour créer automatiquement un nouveau spreadsheet au premier run
# Format : l'ID est dans l'URL https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=
